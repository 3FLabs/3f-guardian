{
  "name": "@3flabs/guardian-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "test:watch": "bun run --filter '*' test:watch",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "oxlint packages/*/src packages/*/tests",
    "lint:fix": "oxlint --fix packages/*/src packages/*/tests",
    "format": "oxfmt packages/*/src packages/*/tests",
    "format:check": "oxfmt --check packages/*/src packages/*/tests",
    "changeset": "changeset",
    "changeset:version": "changeset version && bun install --lockfile-only",
    "changeset:publish": "bun run build && bun run scripts/rewrite-workspace-deps.ts && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/bun": "latest",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  }
}
