{
  "name": "@3flabs/guardian",
  "version": "0.2.0",
  "description": "HTTP shell for the Guardian off-chain signer service. Hosts plug in policy & signing via a typed abstractions contract.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:clean": "rm -rf dist && bun run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@elysiajs/openapi": "^1.4.15",
    "@noble/hashes": "^2.2.0",
    "better-result": "^2.9.0",
    "elysia": "^1.4.28",
    "viem": "^2.48.4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/3FLabs/3f-guardian.git",
    "directory": "packages/guardian"
  },
  "license": "MIT",
  "sideEffects": false
}
