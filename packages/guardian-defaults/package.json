{
  "name": "@3flabs/guardian-defaults",
  "version": "0.1.0",
  "description": "Default Logger, in-memory rate limiter, and Appendix-A check builders for @3flabs/guardian.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./logger": {
      "types": "./dist/logger/index.d.ts",
      "import": "./dist/logger/index.js"
    },
    "./rate-limit": {
      "types": "./dist/rate-limit/index.d.ts",
      "import": "./dist/rate-limit/index.js"
    },
    "./checks": {
      "types": "./dist/checks/index.d.ts",
      "import": "./dist/checks/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:clean": "rm -rf dist && bun run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@3flabs/guardian": "workspace:*",
    "better-result": "^2.9.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "viem": "^2.48.4"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/3FLabs/3f-guardian.git",
    "directory": "packages/guardian-defaults"
  },
  "license": "MIT",
  "sideEffects": false
}
